# ------------------------------------------------------------------------------
# Smart Shield API — environment variables
# Copy to `.env` for local development. All vars are read once at startup into a
# typed config struct (internal/platform/config). No os.Getenv elsewhere.
# ------------------------------------------------------------------------------

# HTTP server
APP_ENV=development           # development | production
PORT=8080
LOG_LEVEL=debug              # debug | info | warn | error

# Postgres (pgx pool)
DB_URL=postgres://smartshield:smartshield@localhost:5432/smartshield?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2

# Redis (cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth / JWT — REQUIRED, no default in production.
JWT_SECRET=change-me-in-prod-use-32+-random-bytes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h        # 30 days

# CORS (comma-separated origins; * for all in dev)
CORS_ALLOWED_ORIGINS=*
